{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "bankroll_response_batch_v1_8",
  "type": "object",
  "required": [
    "response_schema_version",
    "bank_policy_version",
    "decision_batch_id",
    "decision_timestamp",
    "selector_run_id",
    "decisions"
  ],
  "properties": {
    "response_schema_version": {
      "type": "string",
      "const": "bankroll_response_batch.v1.8"
    },
    "bank_policy_version": {
      "type": "string"
    },
    "decision_batch_id": {
      "type": "string"
    },
    "decision_timestamp": {
      "type": "string"
    },
    "selector_run_id": {
      "type": "string"
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "bank_schema_version",
          "decision_id",
          "pick_id",
          "module_origin",
          "decision_status",
          "stake_base",
          "stake_suggested",
          "stake_approved",
          "stake_pct_bankroll",
          "bank_state_mode",
          "portfolio_group",
          "exposure_bucket",
          "execution_order",
          "rules_triggered",
          "decision_timestamp",
          "bankroll_note"
        ],
        "properties": {
          "bank_schema_version": {
            "type": "string",
            "const": "bank_decision.v1.1"
          },
          "decision_id": {
            "type": "string"
          },
          "pick_id": {
            "type": "string"
          },
          "module_origin": {
            "type": "string",
            "enum": [
              "v12",
              "corners",
              "btts",
              "cards"
            ]
          },
          "decision_status": {
            "type": "string",
            "enum": [
              "APPROVED",
              "APPROVED_REDUCED",
              "BLOCKED",
              "RESERVE"
            ]
          },
          "stake_base": {
            "type": "number",
            "minimum": 0
          },
          "stake_suggested": {
            "type": "number",
            "minimum": 0
          },
          "stake_approved": {
            "type": "number",
            "minimum": 0
          },
          "stake_pct_bankroll": {
            "type": [
              "number",
              "null"
            ]
          },
          "bank_state_mode": {
            "type": "string",
            "enum": [
              "Normal",
              "Alerta",
              "Defesa",
              "Protecao_Maxima"
            ]
          },
          "portfolio_group": {
            "type": "string",
            "enum": [
              "core",
              "satellite",
              "optional"
            ]
          },
          "exposure_bucket": {
            "type": [
              "string",
              "null"
            ]
          },
          "execution_order": {
            "type": [
              "integer",
              "null"
            ]
          },
          "approved_odds_window": {
            "type": [
              "string",
              "null"
            ]
          },
          "rules_triggered": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "block_reason_code": {
            "type": [
              "string",
              "null"
            ]
          },
          "block_reason_text": {
            "type": [
              "string",
              "null"
            ]
          },
          "decision_timestamp": {
            "type": "string"
          },
          "bankroll_note": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}