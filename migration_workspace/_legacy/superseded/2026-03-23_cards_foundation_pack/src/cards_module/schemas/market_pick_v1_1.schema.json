{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SignalBet Market Pick v1.1",
  "type": "object",
  "required": [
    "schema_version",
    "pick_id",
    "created_at",
    "module_id",
    "module_version",
    "event_id",
    "match_label",
    "competition",
    "market_family",
    "market",
    "selection",
    "eligibility",
    "score_raw",
    "confidence_raw",
    "risk_raw",
    "edge_raw",
    "rationale_summary",
    "main_drivers",
    "penalties",
    "data_quality_flag"
  ],
  "properties": {
    "schema_version": {"const": "market_pick.v1.1"},
    "pick_id": {"type": "string"},
    "created_at": {"type": "string"},
    "module_id": {"type": "string", "const": "cards"},
    "module_version": {"type": "string"},
    "event_id": {"type": ["integer", "string"]},
    "match_label": {"type": "string"},
    "competition": {"type": "string"},
    "kickoff_datetime": {"type": ["string", "null"]},
    "market_family": {"type": "string", "const": "cards"},
    "market": {"type": "string"},
    "selection": {"type": "string"},
    "line": {"type": ["number", "null"]},
    "odds": {"type": ["number", "null"]},
    "eligibility": {"type": "boolean"},
    "score_raw": {"type": "number"},
    "confidence_raw": {"type": "integer", "minimum": 1, "maximum": 4},
    "risk_raw": {"type": "integer", "minimum": 1, "maximum": 4},
    "edge_raw": {"type": "string"},
    "rationale_summary": {"type": "string"},
    "main_drivers": {"type": "array", "items": {"type": "string"}},
    "penalties": {"type": "array", "items": {"type": "string"}},
    "data_quality_flag": {
      "type": "string",
      "enum": ["clean", "partial", "fragile", "invalid"]
    },
    "module_rank_internal": {"type": ["integer", "null"]},
    "expiry_context": {"type": ["string", "null"]},
    "module_specific_payload": {"type": "object"}
  },
  "additionalProperties": true
}
