{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "execution_settlement_hook_required_payload.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "fixture_status",
    "score_home",
    "score_away",
    "is_finished_official",
    "result_timestamp"
  ],
  "properties": {
    "event_id": {
      "type": [
        "integer",
        "string"
      ]
    },
    "fixture_status": {
      "type": "string",
      "description": "official fixture status from Data/API Layer"
    },
    "score_home": {
      "type": [
        "integer",
        "null"
      ]
    },
    "score_away": {
      "type": [
        "integer",
        "null"
      ]
    },
    "is_finished_official": {
      "type": "boolean"
    },
    "result_timestamp": {
      "type": "string"
    },
    "void_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "extra": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}