{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HealthReport",
  "type": "object",
  "required": [
    "run_id",
    "overall_status",
    "checks"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "overall_status": {
      "type": "string",
      "enum": [
        "PASS",
        "WARN",
        "FAIL"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "check_id",
          "status",
          "message",
          "blocking"
        ],
        "properties": {
          "check_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "FAIL"
            ]
          },
          "message": {
            "type": "string"
          },
          "blocking": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "blocking_failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
