{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ModuleRunResult",
  "type": "object",
  "required": [
    "module_id",
    "status",
    "warnings",
    "errors",
    "candidates_count",
    "execution_time_ms"
  ],
  "properties": {
    "module_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "WARN",
        "FAIL",
        "SKIPPED"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidates_count": {
      "type": "integer",
      "minimum": 0
    },
    "candidates_payload_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "execution_time_ms": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
