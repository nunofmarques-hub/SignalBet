{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpportunityPool",
  "type": "object",
  "required": [
    "run_id",
    "source_modules",
    "candidate_count",
    "candidates"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "source_modules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidate_count": {
      "type": "integer",
      "minimum": 0
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false
}
