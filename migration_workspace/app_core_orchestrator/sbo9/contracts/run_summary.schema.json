{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "run_id",
    "run_profile",
    "preflight_status",
    "official_trunk_status",
    "modules_eligible",
    "modules_run",
    "modules_skipped",
    "modules_failed",
    "module_feed_sources",
    "pipeline_steps",
    "final_summary"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "run_profile": {
      "type": "string"
    },
    "preflight_status": {
      "type": "string"
    },
    "official_trunk_status": {
      "type": "string"
    },
    "project_mode": {
      "type": "string"
    },
    "modules_eligible": {
      "type": "array"
    },
    "modules_run": {
      "type": "array"
    },
    "modules_skipped": {
      "type": "array"
    },
    "modules_failed": {
      "type": "array"
    },
    "module_feed_sources": {
      "type": "object"
    },
    "pipeline_steps": {
      "type": "array"
    },
    "final_summary": {
      "type": "string"
    }
  }
}
