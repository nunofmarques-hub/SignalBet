{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Schema C - Bankroll to Execution v1.1",
  "type": "object",
  "required": [
    "bank_schema_version",
    "decision_id",
    "pick_id",
    "module_origin",
    "decision_status",
    "stake_base",
    "stake_suggested",
    "stake_approved",
    "bank_state_mode",
    "portfolio_group",
    "rules_triggered",
    "bankroll_before",
    "daily_exposure_before",
    "daily_exposure_after_if_accepted",
    "decision_timestamp"
  ],
  "properties": {
    "bank_schema_version": {"type": "string", "const": "bank_decision.v1.1"},
    "decision_id": {"type": "string"},
    "pick_id": {"type": "string"},
    "module_origin": {"type": "string", "enum": ["v12", "corners", "btts", "cards"]},
    "decision_status": {"type": "string", "enum": ["APPROVED", "APPROVED_REDUCED", "BLOCKED", "RESERVE"]},
    "stake_base": {"type": "number", "minimum": 0},
    "stake_suggested": {"type": "number", "minimum": 0},
    "stake_approved": {"type": "number", "minimum": 0},
    "stake_pct_bankroll": {"type": ["number", "null"]},
    "bank_state_mode": {"type": "string", "enum": ["Normal", "Alerta", "Defesa", "Protecao_Maxima"]},
    "portfolio_group": {"type": "string", "enum": ["core", "satellite", "optional"]},
    "exposure_bucket": {"type": ["string", "null"]},
    "execution_order": {"type": ["integer", "null"]},
    "approved_odds_window": {"type": ["string", "null"]},
    "rules_triggered": {"type": "array", "items": {"type": "string"}},
    "block_reason_code": {"type": ["string", "null"]},
    "block_reason_text": {"type": ["string", "null"]},
    "bankroll_before": {"type": "number"},
    "daily_exposure_before": {"type": "number"},
    "daily_exposure_after_if_accepted": {"type": "number"},
    "decision_timestamp": {"type": "string"},
    "bankroll_note": {"type": ["string", "null"]}
  },
  "allOf": [
    {
      "if": {"properties": {"decision_status": {"const": "BLOCKED"}}},
      "then": {"required": ["block_reason_code", "block_reason_text"]}
    }
  ],
  "additionalProperties": true
}
