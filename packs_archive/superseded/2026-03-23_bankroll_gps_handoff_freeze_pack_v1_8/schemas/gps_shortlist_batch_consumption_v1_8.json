{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "gps_shortlist_batch_consumption_v1_8",
  "type": "object",
  "required": [
    "batch_schema_version",
    "selector_run_id",
    "generated_at",
    "normalization_version",
    "shortlist_size",
    "picks"
  ],
  "properties": {
    "batch_schema_version": {
      "type": "string",
      "const": "gps_shortlist_batch.v1"
    },
    "selector_run_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "normalization_version": {
      "type": "string",
      "minLength": 1
    },
    "shortlist_size": {
      "type": "integer",
      "minimum": 0
    },
    "picks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "selector_schema_version",
          "pick_id",
          "module_id",
          "module_version",
          "event_id",
          "match_label",
          "market_family",
          "market",
          "selection",
          "odds",
          "global_score",
          "confidence_norm",
          "risk_norm",
          "edge_norm",
          "priority_tier",
          "executive_rationale",
          "pool_status",
          "normalization_version"
        ],
        "properties": {
          "selector_schema_version": {
            "type": "string",
            "const": "selector_pick.v1.1"
          },
          "pick_id": {
            "type": "string",
            "minLength": 1
          },
          "module_id": {
            "type": "string",
            "enum": [
              "v12",
              "corners",
              "btts",
              "cards"
            ]
          },
          "module_version": {
            "type": "string",
            "minLength": 1
          },
          "event_id": {
            "type": [
              "integer",
              "string"
            ]
          },
          "match_label": {
            "type": "string",
            "minLength": 1
          },
          "market_family": {
            "type": "string",
            "enum": [
              "goals",
              "btts",
              "corners",
              "cards"
            ]
          },
          "market": {
            "type": "string",
            "minLength": 1
          },
          "selection": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": [
              "number",
              "integer",
              "null"
            ]
          },
          "odds": {
            "type": "number",
            "minimum": 1.01
          },
          "global_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "confidence_norm": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "risk_norm": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "edge_norm": {
            "type": "string",
            "enum": [
              "weak",
              "acceptable",
              "strong",
              "very_strong"
            ]
          },
          "priority_tier": {
            "type": "string",
            "enum": [
              "Best",
              "Top",
              "Actionable",
              "Watchlist",
              "Reject"
            ]
          },
          "conflict_flags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "correlation_flags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "executive_rationale": {
            "type": "string",
            "minLength": 1
          },
          "selector_decision_note": {
            "type": [
              "string",
              "null"
            ]
          },
          "pool_status": {
            "type": "string",
            "const": "exported_to_bankroll"
          },
          "normalization_version": {
            "type": "string",
            "minLength": 1
          },
          "rank_position": {
            "type": [
              "integer",
              "null"
            ]
          },
          "shortlist_bucket": {
            "type": [
              "string",
              "null"
            ]
          },
          "selection_status": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}