{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "execution-intake.v1",
  "type": "object",
  "required": [
    "schema_version",
    "source_system",
    "decision_id",
    "pick_id",
    "event_id",
    "module_origin",
    "market_family",
    "market",
    "selection",
    "match_label",
    "decision_status",
    "stake_approved",
    "stake_pct_bankroll",
    "approved_odds_reference",
    "approved_odds_window",
    "portfolio_group",
    "execution_order",
    "rules_triggered",
    "decision_timestamp"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "execution-intake.v1"
    },
    "source_system": {
      "type": "string",
      "const": "BANKROLL_RISK_MANAGER"
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "pick_id": {
      "type": "string",
      "minLength": 1
    },
    "global_pick_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "module_origin": {
      "type": "string",
      "minLength": 1
    },
    "module_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "sport": {
      "type": [
        "string",
        "null"
      ]
    },
    "competition_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "market_family": {
      "type": "string",
      "minLength": 1
    },
    "market": {
      "type": "string",
      "minLength": 1
    },
    "selection": {
      "type": "string",
      "minLength": 1
    },
    "match_label": {
      "type": "string",
      "minLength": 1
    },
    "line": {
      "type": [
        "number",
        "null"
      ]
    },
    "side": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision_status": {
      "type": "string",
      "enum": [
        "APPROVED"
      ]
    },
    "stake_approved": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "stake_pct_bankroll": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 1
    },
    "approved_odds_reference": {
      "type": "number",
      "exclusiveMinimum": 1.0
    },
    "approved_odds_window": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?-[0-9]+(\\.[0-9]+)?$"
        },
        {
          "type": "object",
          "required": [
            "min_odds",
            "max_odds"
          ],
          "properties": {
            "min_odds": {
              "type": "number",
              "exclusiveMinimum": 1.0
            },
            "max_odds": {
              "type": "number",
              "exclusiveMinimum": 1.0
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "portfolio_group": {
      "type": "string",
      "enum": [
        "CORE",
        "SUPPORT",
        "TEST",
        "WATCHLIST_EXECUTABLE"
      ]
    },
    "execution_order": {
      "type": "integer",
      "minimum": 1
    },
    "rules_triggered": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bankroll_note": {
      "type": [
        "string",
        "null"
      ]
    },
    "global_score": {
      "type": [
        "number",
        "null"
      ]
    },
    "priority_tier": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence_norm": {
      "type": [
        "number",
        "null"
      ]
    },
    "risk_norm": {
      "type": [
        "number",
        "null"
      ]
    },
    "edge_norm": {
      "type": [
        "number",
        "null"
      ]
    },
    "selector_flags": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "executive_rationale": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "request_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "ingested_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}