{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UiStatus",
  "type": "object",
  "required": [
    "screen_status",
    "run_id",
    "system_health",
    "data_api_health",
    "module_overview",
    "last_run_summary",
    "cta_state"
  ],
  "properties": {
    "screen_status": {
      "type": "string",
      "enum": [
        "NOT_STARTED",
        "RUNNING",
        "PASS",
        "WARN",
        "FAIL",
        "SKIPPED",
        "BLOCKED",
        "COMPLETED"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "system_health": {
      "type": "string"
    },
    "data_api_health": {
      "type": "string"
    },
    "module_overview": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "last_run_summary": {
      "type": "string"
    },
    "blocking_message": {
      "type": [
        "string",
        "null"
      ]
    },
    "cta_state": {
      "type": "string",
      "enum": [
        "enabled",
        "disabled",
        "running"
      ]
    }
  },
  "additionalProperties": false
}
