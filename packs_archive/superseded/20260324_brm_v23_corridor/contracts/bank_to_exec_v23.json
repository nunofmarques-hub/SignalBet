{
  "title": "bank_to_exec_v23",
  "type": "object",
  "required": [
    "execution_batch_schema_version",
    "source_decision_batch_id",
    "intake_timestamp",
    "execution_candidates"
  ],
  "properties": {
    "execution_batch_schema_version": {
      "type": "string",
      "const": "execution_intake_batch.v1"
    },
    "source_decision_batch_id": {
      "type": "string"
    },
    "intake_timestamp": {
      "type": "string"
    },
    "execution_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "execution_intake_schema_version",
          "pick_id",
          "event_id",
          "match_label",
          "market_family",
          "market",
          "selection",
          "odds_snapshot",
          "global_score",
          "priority_tier",
          "decision_status",
          "stake_approved",
          "execution_order",
          "approved_odds_window",
          "execution_note"
        ],
        "properties": {
          "execution_intake_schema_version": {
            "type": "string",
            "const": "execution_intake_candidate.v1"
          },
          "pick_id": {
            "type": "string"
          },
          "event_id": {
            "type": [
              "integer",
              "string"
            ]
          },
          "match_label": {
            "type": "string"
          },
          "market_family": {
            "type": "string"
          },
          "market": {
            "type": "string"
          },
          "selection": {
            "type": "string"
          },
          "line": {
            "type": [
              "number",
              "integer",
              "null"
            ]
          },
          "odds_snapshot": {
            "type": "number"
          },
          "global_score": {
            "type": "integer"
          },
          "priority_tier": {
            "type": "string"
          },
          "decision_status": {
            "type": "string",
            "enum": [
              "APPROVED",
              "APPROVED_REDUCED"
            ]
          },
          "stake_approved": {
            "type": "number"
          },
          "stake_pct_bankroll": {
            "type": [
              "number",
              "null"
            ]
          },
          "execution_order": {
            "type": "integer"
          },
          "approved_odds_window": {
            "type": [
              "string",
              "null"
            ]
          },
          "rules_triggered": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "execution_note": {
            "type": "string"
          }
        }
      }
    }
  }
}